{
  "info": {
    "name": "Finance Portfolio Tracker",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "current_email", "value": "" },
    { "key": "token", "value": "" },
    { "key": "investmentId1", "value": "" },
    { "key": "investmentId2", "value": "" }
  ],
  "item": [
    {
      "name": "1. Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let email = 'dhanush_' + pm.variables.replaceIn('{{$timestamp}}') + '@gmail.com';",
              "pm.collectionVariables.set('current_email', email);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"name\":\"Dhanush\",\"email\":\"{{current_email}}\",\"password\":\"Password@123\"}"
        },
        "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
      }
    },
    {
      "name": "2. Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set('token', jsonData.accessToken);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\"email\":\"{{current_email}}\",\"password\":\"Password@123\"}"
        },
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
      }
    },
    {
      "name": "3. Get Me",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
      }
    },
    {
      "name": "4. Create Investment 1",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set('investmentId1', jsonData.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"investmentName\":\"Apple Stock\",\"investmentType\":\"Stock\",\"investedAmount\":5000,\"currentValue\":5500,\"purchaseDate\":\"2024-01-01T00:00:00Z\"}"
        },
        "url": { "raw": "{{baseUrl}}/investments", "host": ["{{baseUrl}}"], "path": ["investments"] }
      }
    },
    {
      "name": "5. Create Investment 2",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
              "var jsonData = pm.response.json();",
              "pm.collectionVariables.set('investmentId2', jsonData.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"investmentName\":\"Bitcoin\",\"investmentType\":\"Crypto\",\"investedAmount\":2000,\"currentValue\":2200,\"purchaseDate\":\"2024-02-01T00:00:00Z\"}"
        },
        "url": { "raw": "{{baseUrl}}/investments", "host": ["{{baseUrl}}"], "path": ["investments"] }
      }
    },
    {
      "name": "6. Get Investments",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "var jsonData = pm.response.json();",
              "pm.test('Has at least 2 investments', function () { pm.expect(jsonData.length).to.be.at.least(2); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/investments", "host": ["{{baseUrl}}"], "path": ["investments"] }
      }
    },
    {
      "name": "7. Update Investment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"currentValue\":6000}"
        },
        "url": { "raw": "{{baseUrl}}/investments/{{investmentId1}}", "host": ["{{baseUrl}}"], "path": ["investments", "{{investmentId1}}"] }
      }
    },
    {
      "name": "8. Get Portfolio Summary",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "var jsonData = pm.response.json();",
              "pm.test('Total invested is 7000', function () { pm.expect(Number(jsonData.totalInvested)).to.eql(7000); });",
              "pm.test('Current value is 8200', function () { pm.expect(Number(jsonData.currentValue)).to.eql(8200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/portfolio/summary", "host": ["{{baseUrl}}"], "path": ["portfolio", "summary"] }
      }
    },
    {
      "name": "9. Delete Investment",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/investments/{{investmentId2}}", "host": ["{{baseUrl}}"], "path": ["investments", "{{investmentId2}}"] }
      }
    },
    {
      "name": "10. Get Portfolio Summary (After Delete)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
              "var jsonData = pm.response.json();",
              "pm.test('Total invested is 5000', function () { pm.expect(Number(jsonData.totalInvested)).to.eql(5000); });",
              "pm.test('Current value is 6000', function () { pm.expect(Number(jsonData.currentValue)).to.eql(6000); });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" }
        ],
        "url": { "raw": "{{baseUrl}}/portfolio/summary", "host": ["{{baseUrl}}"], "path": ["portfolio", "summary"] }
      }
    }
  ]
}
